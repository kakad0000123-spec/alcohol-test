{
  "crons": [
    {
      "path": "/api/cron/report?session=AM",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/report?session=PM",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/report?session=Night",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/backup",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/line-notify",
      "schedule": "* * * * *"
    }
  ]
}
